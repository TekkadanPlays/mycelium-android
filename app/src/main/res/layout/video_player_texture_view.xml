<?xml version="1.0" encoding="utf-8"?>
<!-- PlayerView configured with TextureView to prevent HDR video from
     overriding Night Mode. SurfaceView renders in a separate window layer
     that forces HDR color mode on the display, breaking dark theme.
     TextureView composites through the normal View hierarchy. -->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit"
    app:show_buffering="when_playing" />
